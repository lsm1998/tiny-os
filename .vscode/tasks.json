{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0", 
    "tasks": [
        {
            "label": "VSCode 调试准备",
            "type": "shell",
            "command": "bash ${workspaceFolder}/script/vscode-debug-osx.sh prepare",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "停止 QEMU 调试",
            "type": "shell",
            "command": "bash ${workspaceFolder}/script/vscode-debug-osx.sh stop",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "never",
                "panel": "dedicated"
            },
            "problemMatcher": []
        },
        {
            "label": "写映像文件",
            "type": "shell",
            "command": "bash ${workspaceFolder}/script/img-write-osx.sh",
            "windows": {
                // windows下特殊一些
                "command": "${workspaceFolder}/script/img-write-win.bat",
            },
            "linux":{
                "command": "bash ${workspaceFolder}/script/img-write-linux.sh"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "启动qemu",
            "type": "shell",
            "command": "bash ${workspaceFolder}/script/qemu-debug-osx.sh",
            "windows": {
                // windows下特殊一些
                "command": "${workspaceFolder}/script/qemu-debug-win.bat",
            },
            "linux":{
                "command": "bash ${workspaceFolder}/script/qemu-debug-linux.sh",
            },
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "label": "调试准备",
            "dependsOrder": "sequence",
            "dependsOn": [
                "写映像文件",
                "启动qemu"
            ],
        }
    ]
}
