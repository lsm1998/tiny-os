{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) 后台手动调试",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/boot/boot.elf",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "logging": {
                "engineLogging": false,
                "trace": false,
                "traceResponse": false
            },
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "x86_64-elf-gdb",
            "miDebuggerServerAddress": "127.0.0.1:1234",
            "targetArchitecture": "x86",
            "stopAtConnect": false,
            "serverLaunchTimeout": 30000,
            "launchCompleteCommand": "exec-continue",
            "windows": {
                "preLaunchTask": "调试准备",
            },
            "linux": {
                "preLaunchTask": "调试准备",
                "miDebuggerPath": "gdb",
            },
            "osx": {
                "preLaunchTask": "VSCode 调试准备",
                "postDebugTask": "停止 QEMU 调试",
                "miDebuggerPath": "gdb"
            },
            "customLaunchSetupCommands": [],
            "setupCommands": [
                {
                    "description": "在连接远程 QEMU 前加载 boot 符号，确保 UI 源码断点能绑定到 start.S",
                    "text": "-file-exec-and-symbols ${workspaceFolder}/build/src/boot/boot.elf",
                    "ignoreFailures": false
                },
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "将反汇编风格设置为 Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "设置体系结构",
                    "text": "-gdb-set arch i8086",
                    "ignoreFailures": true
                },
                {
                    "description": "加载loader符号文件",
                    "text": "add-symbol-file ${workspaceFolder}/build/src/loader/loader.elf 0x8000",
                    "ignoreFailures": false
                },
                {
                    "description": "加载kernel符号文件",
                    "text": "add-symbol-file ${workspaceFolder}/build/src/kernel/kernel.elf 0x100000",
                    "ignoreFailures": false
                }
            ],
        },
        {
            "name": "(gdb) QEMU界面手动调试",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/src/boot/boot.elf",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "logging": {
                "engineLogging": false,
                "trace": false,
                "traceResponse": false
            },
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "x86_64-elf-gdb",
            "miDebuggerServerAddress": "127.0.0.1:1234",
            "targetArchitecture": "x86",
            "stopAtConnect": false,
            "serverLaunchTimeout": 30000,
            "launchCompleteCommand": "exec-continue",
            "windows": {
                "preLaunchTask": "调试准备",
            },
            "linux": {
                "preLaunchTask": "调试准备",
                "miDebuggerPath": "gdb",
            },
            "osx": {
                "preLaunchTask": "VSCode 调试准备（保留QEMU界面）",
                "postDebugTask": "停止 QEMU 调试（保留QEMU界面）",
                "miDebuggerPath": "gdb"
            },
            "customLaunchSetupCommands": [],
            "setupCommands": [
                {
                    "description": "在连接远程 QEMU 前加载 boot 符号，确保 UI 源码断点能绑定到 start.S",
                    "text": "-file-exec-and-symbols ${workspaceFolder}/build/src/boot/boot.elf",
                    "ignoreFailures": false
                },
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "将反汇编风格设置为 Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "设置体系结构",
                    "text": "-gdb-set arch i8086",
                    "ignoreFailures": true
                },
                {
                    "description": "加载loader符号文件",
                    "text": "add-symbol-file ${workspaceFolder}/build/src/loader/loader.elf 0x8000",
                    "ignoreFailures": false
                },
                {
                    "description": "加载kernel符号文件",
                    "text": "add-symbol-file ${workspaceFolder}/build/src/kernel/kernel.elf 0x100000",
                    "ignoreFailures": false
                }
            ],
        }
    ]
}
